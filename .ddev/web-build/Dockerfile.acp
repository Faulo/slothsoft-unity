# Install agent utilities and a system browser for local visual checks.
ENV CHROME_BIN=/usr/bin/chromium
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        chromium \
        chromium-sandbox \
        ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Install Codex CLI globally in the DDEV web container.
ENV INITIAL_AGENT_MODE=agent-full-access

RUN npm install -g  \
    @openai/codex@latest  \
    @agentclientprotocol/codex-acp@latest \
    && codex --version \
    && codex-acp --version \

# Install Claude Code CLI globally in the DDEV web container. \
ENV ACP_PERMISSION_MODE=bypassPermissions
ENV CLAUDE_SKIP_TRUST_DIALOG=1
ENV ANTHROPIC_MODEL=claude-sonnet-4-6

RUN npm install -g  \
    @agentclientprotocol/claude-agent-acp@latest \
    @anthropic-ai/claude-code@latest \
    && claude --version \
    && claude-agent-acp --version
