# Base tools + locale
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    git-lfs \
    gnupg \
    locales \
    nano \
    pciutils \
    tini \
    wget \
    extrepo \
    zip \
    unzip && \
    echo "$LANG UTF-8" > /etc/locale.gen && \
    locale-gen "$LANG" && \
    install -m 0755 -d /etc/apt/keyrings && \
    curl --version && \
    git --version && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Legacy Unity editor compatibility
ENV DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        libdbus-glib-1-2 \
        xauth && \
    curl -fsSL https://security.debian.org/debian-security/pool/updates/main/o/openssl/libssl1.1_1.1.1w-0+deb11u8_amd64.deb -o /tmp/libssl1.1.deb && \
    curl -fsSL http://deb.debian.org/debian/pool/main/g/gconf/gconf2-common_3.2.6-8_all.deb -o /tmp/gconf2-common.deb && \
    curl -fsSL http://deb.debian.org/debian/pool/main/g/gconf/libgconf-2-4_3.2.6-8_amd64.deb -o /tmp/libgconf-2-4.deb && \
    apt-get install -y --no-install-recommends \
        /tmp/libssl1.1.deb \
        /tmp/gconf2-common.deb \
        /tmp/libgconf-2-4.deb && \
    rm -f /tmp/libssl1.1.deb /tmp/gconf2-common.deb /tmp/libgconf-2-4.deb && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Unity Hub
RUN install -m 0755 -d /etc/apt/keyrings && \
    curl -fsSL https://hub.unity3d.com/linux/keys/public | gpg --dearmor -o /etc/apt/keyrings/unityhub.gpg && \
    chmod a+r /etc/apt/keyrings/unityhub.gpg && \
    echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/unityhub.gpg] https://hub.unity3d.com/linux/repos/deb stable main" \
        > /etc/apt/sources.list.d/unityhub.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        cpio \
        desktop-file-utils \
        ffmpeg \
        libasound2 \
        libc6-dev \
        libgbm-dev \
        libglu1-mesa \
        p7zip-full \
        python3 \
        unityhub=3.12.1 \
        xvfb \
        xz-utils && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
